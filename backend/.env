# Flask
FLASK_ENV=development
PORT=5000

# CORS — comma-separated list of allowed request origins.
# Includes Expo web dev server (8081) and the Docker host-mapped port (5001).
ALLOWED_ORIGINS=http://localhost:8081,http://localhost:5001,http://localhost:5000,http://127.0.0.1:8081,http://127.0.0.1:5001,http://127.0.0.1:5000,https://aurafractor.web.app,https://aurafractor.firebaseapp.com

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/music_separation

# JWT
JWT_SECRET=dev-secret-key-change-in-production

# Google Cloud Storage (mock for now)
GCS_BUCKET=music-separation-bucket-dev
GOOGLE_APPLICATION_CREDENTIALS=/path/to/gcp-key.json

# Google Cloud Tasks (mock for now)
GCP_PROJECT_ID=your-gcp-project
GCP_REGION=us-central1

# Cloud Run workers (will implement later)
DEMUCS_WORKER_URL=https://demucs-worker-XXXX.run.app
SPLEETER_WORKER_URL=https://spleeter-worker-XXXX.run.app

# Feature flags
ENABLE_MOCK_RESPONSES=true
DEBUG_MODE=true

# Dev / owner bypass: device IDs listed here always register as Studio tier (unlimited credits).
# Find your device_id in the app's first POST /auth/register response, then add it here.
# Comma-separated: DEV_DEVICE_IDS=ios-abc123,android-xyz456
DEV_DEVICE_IDS=
