# Copy to terraform.tfvars and fill in real values
# terraform.tfvars is gitignored

project_id         = "your-gcp-project-id"
region             = "us-central1"
environment        = "staging"
image              = "gcr.io/your-gcp-project-id/aurafractor-api:latest"
db_connection_name = "your-gcp-project-id:us-central1:aurafractor-db"
min_instances      = 0   # set to 1 for production to avoid cold starts
max_instances      = 10
